#!/usr/bin/env bash

get_script_dir() {
    local source="${BASH_SOURCE[0]}"
    while [[ -L "$source" ]]; do
        local dir
        dir="$(cd -P "$(dirname "$source")" 2>/dev/null && pwd)"
        source="$(readlink "$source")"
        [[ "$source" != /* ]] && source="$dir/$source"
    done
    echo "$(cd -P "$(dirname "$source")" 2>/dev/null && pwd)"
}

BASE_DIR="$(get_script_dir)"

shopt -s nullglob
for f in "$BASE_DIR/filemanagement/"*.sh; do
    [[ -f "$f" ]] && source "$f"
done

render_menu() {
    if $move_mode || $copy_mode; then
        echo "c) Confirm   x) Cancel"
        return
    fi
    echo "u) Up directory  cd) change directory r) Rename Current Directory"
    echo "m) Move Items  d) Delete items c) Copy items"
    echo "n) New folders  f) New files  q/h) Quit/Home"
}

init_path "$@"

while true; do

    render_directory
    render_menu

    read -p "Select item number: " choice

    if $move_mode; then
        handle_move_mode && continue
    fi

    if $copy_mode; then
        handle_copy_mode && continue
    fi

    case "$choice" in
        q|Q|h|H) exit 0 ;;
        u|U) go_up ;;
        n|N) create_dirs ;;
        f|F) create_files ;;
        m|M) move_items ;;
        d|D) delete_items ;;
        c|C) initiate_copy ;;
        r|R) rename_item "$path" ;;
        cd|CD|cD|Cd)
            cd "$path" && exec "$SHELL"
            ;;
        *)
            select_item "$choice"
            ;;
    esac

done
