#!/usr/bin/env bash

source "0_state.sh"
source "1_handlepath.sh"
source "2u_up.sh"
source "3nf_handlecreate.sh"
source "4d_handledelete.sh"

source "copyitems.sh"
source "moveitems.sh"
source "modemenu.sh"

source "0_handlefile.sh"
source "0handlerun.sh"
source "1handleopen.sh"
source "7handlerename.sh"
source "8share.sh"


render_menu() {
    if $move_mode || $copy_mode; then
        echo "c) Confirm   x) Cancel"
        return
    fi
    echo "u) Up directory  cd) change directory r) Rename Current Directory"
    echo "m) Move Items  d) Delete items c) Copy items"
    echo "n) New folders  f) New files  q/h) Quit/Home"
}

init_path "$@"

shopt -s nullglob

while true; do

    render_directory
    render_menu

    read -p "Select item number: " choice

    if $move_mode; then
        handle_move_mode && continue
    fi

    if $copy_mode; then
        handle_copy_mode && continue
    fi

    case "$choice" in
        q|Q|h|H) exit 0 ;;
        u|U) go_up ;;
        n|N) create_dirs ;;
        f|F) create_files ;;
        m|M) move_items ;;
        d|D) delete_items ;;
        c|C) initiate_copy ;;
        r|R) rename_item "$path" ;;
        cd|CD|cD|Cd)
            cd "$path" && exec "$SHELL"
            ;;
        *)
            select_item "$choice"
            ;;
    esac

done
