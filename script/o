#!/usr/bin/env bash

source "0_run.sh"
source "0_organise.sh"
source "0_find.sh"
source "bashbasicsbyvk_settings.sh"

MAX_ITEMS=200
force_show=false
in_group_view=false
current_group_letter=""
last_path=""

parse_selection() {
    local input="$1"
    local max="$2"
    local -a indices=()
    IFS=',' read -ra parts <<< "$input"
    for part in "${parts[@]}"; do
        part=$(echo "$part" | xargs)
        if [[ $part =~ ^([0-9]+)-([0-9]+)$ ]]; then
            local start="${BASH_REMATCH[1]}"
            local end="${BASH_REMATCH[2]}"
            for ((i=start; i<=end && i<=max; i++)); do
                indices+=("$i")
            done
        elif [[ $part =~ ^[0-9]+$ ]]; then
            local num="$part"
            (( num >= 1 && num <= max )) && indices+=("$num")
        fi
    done
    echo "${indices[@]}"
}

select_items_common() {
    local prompt="$1"
    if [ ${#items[@]} -eq 0 ]; then
        echo "❌ No items available"
        return 1
    fi
    echo "$prompt (supports ranges: 1-10,15-20,33)"
    read -p "Item numbers: " itemlist
    local indices=($(parse_selection "$itemlist" "${#items[@]}"))
    selected_items=()
    for idx in "${indices[@]}"; do
        selected_items+=("${items[$((idx-1))]}")
    done
    if [ ${#selected_items[@]} -eq 0 ]; then
        echo "❌ No valid items selected"
        return 1
    fi
    echo "📦 Selected:"
    for item in "${selected_items[@]}"; do
        echo "   - $(basename "$item")"
    done
    return 0
}

rename_item() {
    local target="$1"
    local dir newname
    if [ -d "$target" ]; then
        dir=$(dirname -- "$target")
        read -p "📝 Enter new folder name for '$(basename "$target")': " newname
        mv -v "$target" "$dir/$newname"
    elif [ -f "$target" ]; then
        dir=$(dirname -- "$target")
        read -p "📝 Enter new file name for '$(basename "$target")': " newname
        mv -v "$target" "$dir/$newname"
    else
        echo "❌ Cannot rename: '$target' not found." >&2
        return 1
    fi
}

get_abs_path() {
    local target="$1"
    if [ -d "$target" ]; then
        cd -- "$target" && pwd
    elif [ -f "$target" ]; then
        local dir=$(dirname -- "$target")
        local base=$(basename -- "$target")
        echo "$(cd -- "$dir" && pwd)/$base"
    else
        echo "Error: '$target' does not exist" >&2
        return 1
    fi
}

create_files() {
    read -p "📄 Enter filenames (separated by ,): " filelist
    IFS=',' read -ra files <<< "$filelist"
    for file in "${files[@]}"; do
        touch "$path/$file"
        echo "✅ Created file: $file"
    done
}

create_dirs() {
    read -p "📂 Enter folder names (separated by ,): " dirlist
    IFS=',' read -ra dirs <<< "$dirlist"
    for dir in "${dirs[@]}"; do
        mkdir -p "$path/$dir"
        echo "✅ Created folder: $dir"
    done
}

move_items() {
    if select_items_common "MOVE"; then
        original_path="$path"
        path="$HOME"
        move_mode=true
        echo "🌍 MOVE MODE: Navigate to destination folder (press 'c' to confirm, 'x' to cancel)"
    fi
}

delete_items() {
    if select_items_common "DELETE"; then
        echo "⚠️  WARNING: You are about to delete the following items:"
        for item in "${selected_items[@]}"; do
            echo "- $(basename "$item")"
        done
        read -p "Are you sure? This cannot be undone. (y/n): " confirm
        if [[ $confirm != "y" && $confirm != "Y" ]]; then
            echo "🚫 Deletion cancelled"
            return
        fi
        for item in "${selected_items[@]}"; do
            rm -rf -- "$item" && echo "🗑️  Deleted: $(basename "$item")"
        done
    fi
}

initiate_copy() {
    if select_items_common "COPY"; then
        echo "Choose copy target:"
        echo "1) Local (navigate)"
        echo "2) Google Drive via rclone"
        read -p "Enter choice [1-2]: " copy_choice
        case "$copy_choice" in
            1)
                original_path="$path"
                path="$HOME"
                copy_mode=true
                echo "📋 COPY MODE: Navigate to destination folder (press 'c' to confirm, 'x' to cancel)"
                ;;
            2)
                if ! command -v rclone >/dev/null 2>&1; then
                    echo "❌ rclone not found in PATH."
                    selected_items=()
                    return
                fi
                local remote_path="gdrive:/rclone"
                for item in "${selected_items[@]}"; do
                    local base=$(basename "$item")
                    echo "📤 Copying $base → gdrive..."
                    rclone copy "$item" "$remote_path/$base" --progress --metadata
                done
                selected_items=()
                ;;
            *)
                selected_items=()
                ;;
        esac
    fi
}

perform_copy() {
    for item in "${selected_items[@]}"; do
        [ ! -e "$item" ] && continue
        local base=$(basename -- "$item")
        local name="${base%.*}"
        local ext="${base##*.}"
        [[ "$base" == "$ext" ]] && ext=""
        local count=1
        local newbase="$base"
        while [ -e "$path/$newbase" ]; do
            if [ -n "$ext" ]; then
                newbase="${name}_${count}.${ext}"
            else
                newbase="${name}_${count}"
            fi
            count=$((count+1))
        done
        cp -r -- "$item" "$path/$newbase"
        echo "📋 Copied: $(basename "$item") → $newbase"
    done
}

path=$(pwd)
move_mode=false
copy_mode=false
selected_items=()
original_path=""
shopt -s nullglob

if [ $# -eq 1 ]; then
    target="$1"
    if [ -d "$target" ]; then
        path=$(get_abs_path "$target")
    elif [ -f "$target" ]; then
        selected=$(get_abs_path "$target")
        handle_file "$selected"
        exit $?
    else
        echo "❌ Error: '$target' not found" >&2
        exit 1
    fi
fi

while true; do
    echo
    if [ "$path" != "$last_path" ]; then
        force_show=false
        in_group_view=false
        current_group_letter=""
        last_path="$path"
    fi
    if $move_mode; then
        echo "🚚 MOVE MODE: Select destination folder"
    elif $copy_mode; then
        echo "📋 COPY MODE: Select destination folder"
    else
        echo "📂 Location: $path"
    fi

    all_items=()
    if $show_all_types; then
        for f in "$path"/{*,.*}; do
            [ -e "$f" ] || continue
            [[ "$(basename "$f")" == "." || "$(basename "$f")" == ".." ]] && continue
            all_items+=("$f")
        done
    else
        for f in "$path"/*; do
            [ -e "$f" ] || continue
            all_items+=("$f")
        done
    fi

    total=${#all_items[@]}

    if [ $total -eq 0 ]; then
        echo "🛑 This directory is empty"
        items=()
    elif (( total > MAX_ITEMS )) && [ "$force_show" != true ] && [ "$in_group_view" != true ]; then
        declare -A folder_groups
        declare -A file_groups
        declare -A folder_counts
        declare -A file_counts
        for item in "${all_items[@]}"; do
            base=$(basename "$item")
            first_char="${base:0:1}"
            first_char="${first_char^^}"
            if [[ ! "$first_char" =~ [A-Z] ]]; then
                first_char="#"
            fi
            if [ -d "$item" ]; then
                folder_groups[$first_char]+="$item|"
                folder_counts[$first_char]=$(( ${folder_counts[$first_char]:-0} + 1 ))
            else
                file_groups[$first_char]+="$item|"
                file_counts[$first_char]=$(( ${file_counts[$first_char]:-0} + 1 ))
            fi
        done
        echo "📂 Too many items ($total). Grouped alphabetically."
        if [ ${#folder_counts[@]} -ne 0 ]; then
            echo "Folders:"
            for k in $(printf "%s\n" "${!folder_counts[@]}" | sort); do
                printf " %s) %d\n" "$k" "${folder_counts[$k]}"
            done
        else
            echo "Folders: none"
        fi
        if [ ${#file_counts[@]} -ne 0 ]; then
            echo "Files:"
            for k in $(printf "%s\n" "${!file_counts[@]}" | sort); do
                printf " %s) %d\n" "$k" "${file_counts[$k]}"
            done
        else
            echo "Files: none"
        fi
        echo "FORCESHOW) Show all items without grouping"
        echo "Type a letter to view items starting with that letter"
        read -p "Select group letter or command: " choice
        choice_trimmed=$(echo "$choice" | xargs)
        choice_upper="${choice_trimmed^^}"
        if [[ "$choice_upper" == "FORCESHOW" ]]; then
            force_show=true
            continue
        fi
        if [[ "$choice_upper" =~ ^[A-Z]$ || "$choice_upper" == "#" ]]; then
            in_group_view=true
            current_group_letter="$choice_upper"
            items=()
            if [ -n "${folder_groups[$current_group_letter]}" ]; then
                IFS='|' read -ra tmp <<< "${folder_groups[$current_group_letter]}"
                for x in "${tmp[@]}"; do
                    [ -n "$x" ] && items+=("$x")
                done
            fi
            if [ -n "${file_groups[$current_group_letter]}" ]; then
                IFS='|' read -ra tmpf <<< "${file_groups[$current_group_letter]}"
                for x in "${tmpf[@]}"; do
                    [ -n "$x" ] && items+=("$x")
                done
            fi
            if [ ${#items[@]} -eq 0 ]; then
                echo "No items for letter '$current_group_letter'"
                in_group_view=false
                current_group_letter=""
                items=()
                continue
            fi
        else
            echo "⚠️  Invalid selection"
            continue
        fi
    else
        items=("${all_items[@]}")
    fi

    if [ ${#items[@]} -eq 0 ]; then
        :
    else
        idx=1
        for item in "${items[@]}"; do
            [ -d "$item" ] && icon="📁" || icon="📄"
            printf "%2d) %s %s\n" "$idx" "$icon" "$(basename "$item")"
            idx=$((idx+1))
        done
    fi

    echo
    if $move_mode || $copy_mode; then
        echo "c) Confirm   x) Cancel   back) Back to groups"
    else
        if [ "$in_group_view" = true ]; then
            echo "back) Back to groups"
        fi
        echo "u) Up directory   cd) change directory   t) Transfer (move/copy)"
        echo "d) Delete  c) Create  f) Find  x) Organise  r) Rename"
        echo "q/h) Quit/Home s) Settings"
    fi

    read -p "Select item number or command: " choice

    choice_trimmed=$(echo "$choice" | xargs)
    choice_upper="${choice_trimmed^^}"

    if [[ "$choice_upper" == "FORCESHOW" ]]; then
        force_show=true
        in_group_view=false
        current_group_letter=""
        continue
    fi

    if [[ "$choice_upper" == "BACK" || "$choice_upper" == "B" ]]; then
        if [ "$in_group_view" = true ]; then
            in_group_view=false
            current_group_letter=""
            force_show=false
            continue
        fi
    fi

    if $move_mode; then
        case "$choice_trimmed" in
            c|C)
                for item in "${selected_items[@]}"; do
                    mv -v "$item" "$path/"
                done
                echo "✅ Items moved successfully"
                move_mode=false
                path="$original_path"
                selected_items=()
                in_group_view=false
                current_group_letter=""
                continue
                ;;
            x|X)
                echo "🚫 Move operation cancelled"
                move_mode=false
                path="$original_path"
                selected_items=()
                in_group_view=false
                current_group_letter=""
                continue
                ;;
        esac
    fi

    if $copy_mode; then
        case "$choice_trimmed" in
            c|C)
                perform_copy
                echo "✅ Items copied successfully"
                copy_mode=false
                path="$original_path"
                selected_items=()
                in_group_view=false
                current_group_letter=""
                continue
                ;;
            x|X)
                echo "🚫 Copy operation cancelled"
                copy_mode=false
                path="$original_path"
                selected_items=()
                in_group_view=false
                current_group_letter=""
                continue
                ;;
        esac
    fi

    case "$choice_trimmed" in
        q|Q|h|H) exit 0 ;;
        u|U)
            [ "$path" != "/" ] && path=$(dirname "$path")
            in_group_view=false
            current_group_letter=""
            continue
            ;;
        c|C)
            echo "1) New folders"
            echo "2) New files"
            read -p "Choice: " cr
            [[ "$cr" == "1" ]] && create_dirs
            [[ "$cr" == "2" ]] && create_files
            continue
            ;;
        t|T)
            echo "1) Move files/folders"
            echo "2) Copy files/folders"
            read -p "Choice: " tr
            [[ "$tr" == "1" ]] && move_items
            [[ "$tr" == "2" ]] && initiate_copy
            continue
            ;;
        d|D)
            delete_items
            continue
            ;;
        f|F)
            find_menu
            continue
            ;;
        x|X)
            organise_menu
            continue
            ;;
        s|S)
            settings_menu
            continue
            ;;
        r|R)
            echo "1) Select item number to rename (files/folders in current path)"
            echo "2) Rename current path/folder"
            read -p "Choice [1-2]: " ren_choice
            case "$ren_choice" in
                1)
                    if [ ${#items[@]} -eq 0 ]; then
                        echo "❌ No items to rename"
                    else
                        read -p "Enter item number: " num
                        if [[ $num =~ ^[0-9]+$ ]] && [ "$num" -ge 1 ] && [ "$num" -le "${#items[@]}" ]; then
                            rename_item "${items[$((num-1))]}"
                        else
                            echo "❌ Invalid number"
                        fi
                    fi
                    ;;
                2)
                    rename_item "$path"
                    ;;
                *)
                    echo "❌ Invalid choice"
                    ;;
            esac
            continue
            ;;
        cd|CD|cD|Cd)
            cd "$path" && exec "$SHELL"
            ;;
    esac

    if [[ $choice_trimmed =~ ^[0-9]+$ ]] && [ "$choice_trimmed" -ge 1 ] && [ "$choice_trimmed" -le "${#items[@]}" ]; then
        selected="${items[$((choice_trimmed-1))]}"
        if [ -d "$selected" ]; then
            path="$selected"
            in_group_view=false
            current_group_letter=""
        elif [ -f "$selected" ]; then
            if $move_mode || $copy_mode; then
                echo "⚠️  Please select a folder for destination"
            else
                handle_file "$selected"
            fi
        fi
    else
        if [ -n "$choice_trimmed" ]; then
            echo "⚠️  Invalid selection"
        fi
    fi
done
