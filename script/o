#!/usr/bin/env bash

source "bashbasicsbyvk_run.sh"
source "bashbasicsbyvk_organise.sh"
source "bashbasicsbyvk_find.sh"
source "bashbasicsbyvk_settings.sh"

parse_selection() {
local input="$1"
local max="$2"
local -a indices=()
IFS=',' read -ra parts <<< "$input"
for part in "${parts[@]}"; do
part=$(echo "$part" | xargs)
if [[ $part =~ ^([0-9]+)-([0-9]+)$ ]]; then
local start="${BASH_REMATCH[1]}"
local end="${BASH_REMATCH[2]}"
for ((i=start; i<=end && i<=max; i++)); do
indices+=("$i")
done
elif [[ $part =~ ^[0-9]+$ ]]; then
local num="$part"
(( num >= 1 && num <= max )) && indices+=("$num")
fi
done
echo "${indices[@]}"
}

select_items_common() {
local prompt="$1"
if [ ${#items[@]} -eq 0 ]; then
echo "❌ No items available"
return 1
fi
echo "$prompt (supports ranges: 1-10,15-20,33)"
read -p "Item numbers: " itemlist
local indices=($(parse_selection "$itemlist" "${#items[@]}"))
selected_items=()
for idx in "${indices[@]}"; do
selected_items+=("${items[$((idx-1))]}")
done
if [ ${#selected_items[@]} -eq 0 ]; then
echo "❌ No valid items selected"
return 1
fi
return 0
}

select_imaginary_items_common() {
local p="$1"
local pfx="$2"
echo "Select group numbers (supports ranges: 1-3,5):"
read -p "Group numbers: " grplist
local indices=($(parse_selection "$grplist" "${#imaginary_map[@]}"))
if [ "${#indices[@]}" -eq 0 ]; then
echo "❌ No valid groups selected"
return 1
fi
selected_items=()
for idx in "${indices[@]}"; do
local ch="${imaginary_map[$((idx-1))]}"
local ch_lower="${ch,,}"
while IFS= read -r -d '' f; do
local bn="${f##*/}"
[[ "$bn" == "." || "$bn" == ".." ]] && continue
! $show_hidden_files && [[ "$bn" == .* ]] && continue
local bn_lower="${bn,,}"
[[ "$bn_lower" != "$pfx"* ]] && continue
local next_char="${bn_lower:${#pfx}:1}"
if [ "$ch" == "#" ]; then
[[ "$next_char" =~ ^[a-z]$ ]] && continue
else
[[ "$next_char" != "$ch_lower" ]] && continue
fi
selected_items+=("$f")
done < <(find "$p" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
done
local -A _seen=()
local unique=()
for f in "${selected_items[@]}"; do
[ -z "${_seen[$f]+x}" ] && unique+=("$f") && _seen["$f"]=1
done
selected_items=("${unique[@]}")
if [ "${#selected_items[@]}" -eq 0 ]; then
echo "❌ No items found for selected groups"
return 1
fi
return 0
}

rename_item() {
local target="$1"
local dir newname
if [ -d "$target" ]; then
dir=$(dirname -- "$target")
read -p "📝 Enter new folder name for '$(basename "$target")': " newname
mv -v "$target" "$dir/$newname"
elif [ -f "$target" ]; then
dir=$(dirname -- "$target")
read -p "📝 Enter new file name for '$(basename "$target")': " newname
mv -v "$target" "$dir/$newname"
else
echo "❌ Cannot rename: '$target' not found." >&2
return 1
fi
}

get_abs_path() {
local target="$1"
if [ -d "$target" ]; then
cd -- "$target" && pwd
elif [ -f "$target" ]; then
local dir=$(dirname -- "$target")
local base=$(basename -- "$target")
echo "$(cd -- "$dir" && pwd)/$base"
else
echo "Error: '$target' does not exist" >&2
return 1
fi
}

create_files() {
read -p "📄 Enter filenames (separated by ,): " filelist
IFS=',' read -ra files <<< "$filelist"
for file in "${files[@]}"; do
touch "$path/$file"
echo "✅ Created file: $file"
done
}

create_dirs() {
read -p "📂 Enter folder names (separated by ,): " dirlist
IFS=',' read -ra dirs <<< "$dirlist"
for dir in "${dirs[@]}"; do
mkdir -p "$path/$dir"
echo "✅ Created folder: $dir"
done
}

# ─────────────────────────────────────────────
# INTERACTIVE LOCAL NAVIGATOR
# Used for: picking source items or destination folder on local filesystem
# Returns via global: nav_result_path
# Mode: "source" → user selects file(s)/folder(s) and confirms
#        "dest"   → user navigates to a folder and confirms
# ─────────────────────────────────────────────
local_navigator() {
local mode="$1"          # "source" or "dest"
local start_path="${2:-$HOME}"
local nav_path="$start_path"
local nav_prefix=""
local nav_force_show=false
nav_result_path=""
nav_selected_items=()

while true; do
echo
if [ "$mode" == "source" ]; then
echo "📂 SELECT SOURCE — Location: $nav_path${nav_prefix:+ [filter: ${nav_prefix^^}*]}"
else
echo "📂 SELECT DESTINATION — Location: $nav_path${nav_prefix:+ [filter: ${nav_prefix^^}*]}"
fi

local nav_total
nav_total=$(count_items_in_path "$nav_path")
local nav_imaginary=false
local nav_items=()

if [ "$nav_total" -gt "${index_mode_threshold:-200}" ] && ! $nav_force_show; then
nav_imaginary=true
if [ -n "$nav_prefix" ]; then
local local_arr=()
while IFS= read -r -d '' _f; do
_bn="${_f##*/}"
[[ "$_bn" == "." || "$_bn" == ".." ]] && continue
! $show_hidden_files && [[ "$_bn" == .* ]] && continue
[[ "${_bn,,}" != "$nav_prefix"* ]] && continue
local_arr+=("$_f")
done < <(find "$nav_path" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
local pfx_count="${#local_arr[@]}"
if [ "$pfx_count" -le "${index_mode_threshold:-200}" ]; then
nav_imaginary=false
nav_items=("${local_arr[@]}")
else
display_imaginary_groups "$nav_path" "$nav_prefix" "$pfx_count"
fi
else
display_imaginary_groups "$nav_path" "" "$nav_total"
fi
fi

if ! $nav_imaginary; then
if [ ${#nav_items[@]} -eq 0 ] && [ -n "$nav_prefix" ]; then
build_items_for_prefix "$nav_path" "$nav_prefix"
nav_items=("${items[@]}")
elif [ ${#nav_items[@]} -eq 0 ]; then
build_all_items "$nav_path"
nav_items=("${items[@]}")
fi
if [ ${#nav_items[@]} -eq 0 ]; then
echo "🛑 This directory is empty"
else
local idx=1
for item in "${nav_items[@]}"; do
[ -d "$item" ] && icon="📁" || icon="📄"
printf "%2d) %s %s\n" "$idx" "$icon" "$(basename "$item")"
idx=$((idx+1))
done
fi
fi

echo
if [ "$mode" == "source" ]; then
echo "Enter number(s) to select items (supports ranges: 1-3,5)"
echo "u) Up   back) Remove prefix   n) New folder   confirm) Confirm selection   cancel) Cancel"
else
echo "Enter number to enter a subfolder"
echo "u) Up   back) Remove prefix   n) New folder   confirm) Confirm destination   cancel) Cancel"
fi

read -p "Nav: " nav_choice

case "$nav_choice" in
cancel|CANCEL)
echo "🚫 Navigation cancelled"
return 1
;;
confirm|CONFIRM)
if [ "$mode" == "dest" ]; then
nav_result_path="$nav_path"
echo "✅ Destination set: $nav_result_path"
return 0
else
# source mode — require selection
if [ ${#nav_selected_items[@]} -eq 0 ]; then
echo "⚠️  No items selected yet. Select item numbers first, then confirm."
else
echo "✅ Source selection confirmed: ${#nav_selected_items[@]} item(s)"
return 0
fi
fi
;;
u|U)
if [ "$nav_path" != "/" ]; then
nav_path=$(dirname "$nav_path")
nav_prefix=""
nav_force_show=false
fi
;;
back|BACK)
if [ -n "$nav_prefix" ]; then
nav_prefix="${nav_prefix%?}"
nav_force_show=false
fi
;;
n|N)
read -p "📂 New folder name: " new_dir_name
if [ -n "$new_dir_name" ]; then
mkdir -p "$nav_path/$new_dir_name"
echo "✅ Created: $nav_path/$new_dir_name"
if [ "$mode" == "dest" ]; then
nav_path="$nav_path/$new_dir_name"
fi
fi
;;
*)
if $nav_imaginary; then
local matched=false
local ch=""
if [[ "$nav_choice" =~ ^[0-9]+$ ]] && [ "$nav_choice" -ge 1 ] && [ "$nav_choice" -le "${#imaginary_map[@]}" ]; then
ch="${imaginary_map[$((nav_choice-1))]}"
matched=true
elif [[ ${#nav_choice} -eq 1 ]]; then
ch="${nav_choice^^}"
for gc in "${group_chars[@]}"; do
[[ "$gc" == "$ch" ]] && matched=true && break
done
[[ "$matched" == false && "$nav_choice" == "#" ]] && ch="#" && matched=true
fi
if $matched; then
[ "$ch" == "#" ] && nav_prefix="${nav_prefix}#" || nav_prefix="${nav_prefix}${ch,,}"
nav_force_show=false
else
echo "⚠️  Invalid selection"
fi
else
if [[ "$nav_choice" =~ ^[0-9,\-]+$ ]]; then
if [ "$mode" == "source" ]; then
# multi-select for source
local indices=($(parse_selection "$nav_choice" "${#nav_items[@]}"))
for idx in "${indices[@]}"; do
nav_selected_items+=("${nav_items[$((idx-1))]}")
done
echo "✅ Added ${#indices[@]} item(s) to selection (total: ${#nav_selected_items[@]})"
else
# dest: only enter directories
if [[ "$nav_choice" =~ ^[0-9]+$ ]] && [ "$nav_choice" -ge 1 ] && [ "$nav_choice" -le "${#nav_items[@]}" ]; then
local sel="${nav_items[$((nav_choice-1))]}"
if [ -d "$sel" ]; then
nav_path="$sel"
nav_prefix=""
nav_force_show=false
else
echo "⚠️  Please select a folder to navigate into"
fi
else
echo "⚠️  Invalid selection"
fi
fi
else
echo "⚠️  Invalid selection"
fi
fi
;;
esac
done
}

# ─────────────────────────────────────────────
# INTERACTIVE GCLOUD NAVIGATOR (over SSH)
# Navigates remote GCloud Shell filesystem interactively
# Returns via global: gcloud_nav_result_path
# Mode: "source" → pick file(s); "dest" → pick destination folder
# ─────────────────────────────────────────────
gcloud_navigator() {
local mode="$1"   # "source" or "dest"
gcloud_nav_result_path=""
gcloud_nav_selected_items=()

local remote_path
remote_path=$(gcloud cloud-shell ssh --authorize-session --command "echo \$HOME" 2>/dev/null | tail -1)
if [ -z "$remote_path" ]; then
remote_path="~"
fi

while true; do
echo
if [ "$mode" == "source" ]; then
echo "☁️  GCLOUD SOURCE — Location: $remote_path"
else
echo "☁️  GCLOUD DESTINATION — Location: $remote_path"
fi

# List remote directory
local listing
listing=$(gcloud cloud-shell ssh --authorize-session --command "
ls -1Ap '$remote_path' 2>/dev/null
" 2>/dev/null)

local -a remote_items=()
while IFS= read -r line; do
[ -z "$line" ] && continue
remote_items+=("$line")
done <<< "$listing"

if [ ${#remote_items[@]} -eq 0 ]; then
echo "🛑 Remote directory is empty or inaccessible"
else
local idx=1
for item in "${remote_items[@]}"; do
if [[ "$item" == */ ]]; then
printf "%2d) 📁 %s\n" "$idx" "${item%/}"
else
printf "%2d) 📄 %s\n" "$idx" "$item"
fi
idx=$((idx+1))
done
fi

echo
if [ "$mode" == "source" ]; then
echo "Enter number(s) to select items"
echo "u) Up   n) New folder   confirm) Confirm selection   cancel) Cancel"
else
echo "Enter number to enter a subfolder"
echo "u) Up   n) New folder   confirm) Confirm destination   cancel) Cancel"
fi

read -p "GCloud Nav: " gnav_choice

case "$gnav_choice" in
cancel|CANCEL)
echo "🚫 GCloud navigation cancelled"
return 1
;;
confirm|CONFIRM)
if [ "$mode" == "dest" ]; then
gcloud_nav_result_path="$remote_path"
echo "✅ GCloud destination set: $gcloud_nav_result_path"
return 0
else
if [ ${#gcloud_nav_selected_items[@]} -eq 0 ]; then
echo "⚠️  No items selected yet. Select item numbers first, then confirm."
else
echo "✅ GCloud source selection confirmed: ${#gcloud_nav_selected_items[@]} item(s)"
return 0
fi
fi
;;
u|U)
remote_path=$(dirname "$remote_path")
;;
n|N)
read -p "📂 New remote folder name: " new_rdir
if [ -n "$new_rdir" ]; then
gcloud cloud-shell ssh --authorize-session --command "mkdir -p '$remote_path/$new_rdir'" 2>/dev/null
echo "✅ Created remote: $remote_path/$new_rdir"
if [ "$mode" == "dest" ]; then
remote_path="$remote_path/$new_rdir"
fi
fi
;;
*)
if [[ "$gnav_choice" =~ ^[0-9,\-]+$ ]]; then
if [ "$mode" == "source" ]; then
local indices=($(parse_selection "$gnav_choice" "${#remote_items[@]}"))
for idx in "${indices[@]}"; do
local chosen="${remote_items[$((idx-1))]}"
gcloud_nav_selected_items+=("$remote_path/${chosen%/}")
done
echo "✅ Added ${#indices[@]} item(s) to GCloud selection (total: ${#gcloud_nav_selected_items[@]})"
else
if [[ "$gnav_choice" =~ ^[0-9]+$ ]] && [ "$gnav_choice" -ge 1 ] && [ "$gnav_choice" -le "${#remote_items[@]}" ]; then
local sel="${remote_items[$((gnav_choice-1))]}"
if [[ "$sel" == */ ]]; then
remote_path="$remote_path/${sel%/}"
else
echo "⚠️  Please select a folder (📁) to navigate into"
fi
else
echo "⚠️  Invalid selection"
fi
fi
else
echo "⚠️  Invalid input"
fi
;;
esac
done
}

# ─────────────────────────────────────────────
# PERFORM LOCAL COPY (with dedup rename)
# ─────────────────────────────────────────────
perform_copy() {
local dest="$1"
shift
local src_items=("$@")
for item in "${src_items[@]}"; do
[ ! -e "$item" ] && continue
local base=$(basename -- "$item")
local name="${base%.*}"
local ext="${base##*.}"
[[ "$base" == "$ext" ]] && ext=""
local count=1
local newbase="$base"
while [ -e "$dest/$newbase" ]; do
if [ -n "$ext" ]; then
newbase="${name}${count}.${ext}"
else
newbase="${name}${count}"
fi
count=$((count+1))
done
cp -r -- "$item" "$dest/$newbase"
done
}

# ─────────────────────────────────────────────
# PERFORM LOCAL MOVE
# ─────────────────────────────────────────────
perform_move() {
local dest="$1"
shift
local src_items=("$@")
for item in "${src_items[@]}"; do
[ ! -e "$item" ] && continue
mv -- "$item" "$dest/"
done
}

# ─────────────────────────────────────────────
# TRANSFER MENU — Full 4-step flow
# Step 1: Mode
# Step 2: Select source items
# Step 3: Select destination
# Step 4: m/M = move, c/C = copy
# ─────────────────────────────────────────────
transfer_menu() {
# ── STEP 1: Choose mode ──────────────────────
echo
echo "📦 TRANSFER — Step 1: Choose mode"
echo "1) Intra-location  (local → local)"
echo "2) To Drive        (local → Google Drive via rclone)"
echo "3) To GCloud       (local → GCloud Shell)"
echo "4) To Local        (GCloud Shell → local)"
read -p "Mode [1-4]: " t_mode

case "$t_mode" in
1|2|3|4) ;;
*)
echo "❌ Invalid mode"
return
;;
esac

# ── STEP 2: Select source items ─────────────
echo
echo "📦 TRANSFER — Step 2: Select source items"

local step2_ok=false

if [ "$t_mode" == "4" ]; then
# Source is GCloud — navigate remotely
echo "☁️  Establishing GCloud SSH for source navigation..."
if ! command -v gcloud >/dev/null 2>&1; then
echo "❌ gcloud not found in PATH."
return
fi
gcloud cloud-shell ssh --authorize-session --command "echo '✅ SSH ready'" 2>/dev/null
gcloud_navigator "source"
if [ $? -ne 0 ] || [ ${#gcloud_nav_selected_items[@]} -eq 0 ]; then
echo "🚫 Transfer cancelled"
return
fi
step2_ok=true
else
# Source is local
if $imaginary_mode; then
select_imaginary_items_common "$path" "$group_prefix" && step2_ok=true
else
# Use local navigator for source
local_navigator "source" "$path"
if [ $? -eq 0 ] && [ ${#nav_selected_items[@]} -gt 0 ]; then
selected_items=("${nav_selected_items[@]}")
step2_ok=true
fi
fi
fi

if ! $step2_ok; then
echo "🚫 Transfer cancelled — no items selected"
return
fi

# ── STEP 3: Choose destination ───────────────
echo
echo "📦 TRANSFER — Step 3: Choose destination"

local dest_ok=false
local final_dest=""

case "$t_mode" in
1)
# Dest: local navigator
local_navigator "dest" "$HOME"
if [ $? -eq 0 ]; then
final_dest="$nav_result_path"
dest_ok=true
fi
;;
2)
# Dest: Google Drive via rclone
if ! command -v rclone >/dev/null 2>&1; then
echo "❌ rclone not found in PATH."
return
fi
final_dest="gdrive:/rclone"
echo "📍 Destination set to Google Drive: $final_dest"
dest_ok=true
;;
3)
# Dest: GCloud — navigate remotely for destination folder
echo "☁️  Navigating GCloud for destination..."
gcloud_navigator "dest"
if [ $? -eq 0 ]; then
final_dest="$gcloud_nav_result_path"
dest_ok=true
fi
;;
4)
# Dest: local navigator
local_navigator "dest" "$HOME"
if [ $? -eq 0 ]; then
final_dest="$nav_result_path"
dest_ok=true
fi
;;
esac

if ! $dest_ok || [ -z "$final_dest" ]; then
echo "🚫 Transfer cancelled — no destination chosen"
return
fi

# ── STEP 4: Move or Copy ─────────────────────
echo
echo "📦 TRANSFER — Step 4: Action"
echo "c/C) Copy   m/M) Move"
read -p "Action: " t_action

case "$t_action" in
c|C) t_op="copy" ;;
m|M) t_op="move" ;;
*)
echo "❌ Invalid action. Transfer cancelled."
return
;;
esac

# ── EXECUTE ──────────────────────────────────
echo
echo "⚙️  Executing $t_op..."

case "$t_mode" in
1)
# Intra-local copy or move
if [ "$t_op" == "copy" ]; then
perform_copy "$final_dest" "${selected_items[@]}"
echo "✅ Copied ${#selected_items[@]} item(s) → $final_dest"
else
perform_move "$final_dest" "${selected_items[@]}"
echo "✅ Moved ${#selected_items[@]} item(s) → $final_dest"
fi
;;
2)
# Google Drive via rclone
for item in "${selected_items[@]}"; do
local base=$(basename "$item")
if [ "$t_op" == "copy" ]; then
echo "📤 rclone copy: $base → $final_dest/$base"
rclone copy "$item" "$final_dest/$base" --progress --metadata
else
echo "📤 rclone move: $base → $final_dest/$base"
rclone move "$item" "$final_dest/$base" --progress --metadata
fi
done
echo "✅ Drive transfer complete"
;;
3)
# Local → GCloud via scp
echo "☁️  Transferring to GCloud Shell..."
for item in "${selected_items[@]}"; do
local base=$(basename "$item")
echo "📤 Sending $base → GCloud:$final_dest/"
if [ "$t_op" == "copy" ]; then
gcloud cloud-shell scp --recurse "localhost:$item" "cloudshell:$final_dest/"
else
gcloud cloud-shell scp --recurse "localhost:$item" "cloudshell:$final_dest/"
# Remove local after successful transfer
if [ $? -eq 0 ]; then
rm -rf -- "$item"
echo "🗑️  Removed local: $item"
fi
fi
done
echo "✅ Transfer to GCloud complete. SSH session closed."
;;
4)
# GCloud → Local via scp
echo "☁️  Transferring from GCloud Shell to local..."
for remote_item in "${gcloud_nav_selected_items[@]}"; do
local base=$(basename "$remote_item")
echo "📥 Pulling $base from GCloud:$remote_item → $final_dest/"
if [ "$t_op" == "copy" ]; then
gcloud cloud-shell scp --recurse "cloudshell:$remote_item" "localhost:$final_dest/"
else
gcloud cloud-shell scp --recurse "cloudshell:$remote_item" "localhost:$final_dest/"
if [ $? -eq 0 ]; then
gcloud cloud-shell ssh --authorize-session --command "rm -rf '$remote_item'"
echo "🗑️  Removed from GCloud: $remote_item"
fi
fi
done
echo "✅ Transfer from GCloud complete. SSH session closed."
;;
esac

selected_items=()
}

delete_items() {
local _ok=false
if $imaginary_mode; then
select_imaginary_items_common "$path" "$group_prefix" && _ok=true
else
select_items_common "DELETE" && _ok=true
fi
if $_ok; then
read -p "Are you really sure you want to delete the selected files? This action can't be undone. (y/n): " confirm
if [[ $confirm != "y" && $confirm != "Y" ]]; then
echo "🚫 Deletion cancelled"
return
fi
for item in "${selected_items[@]}"; do
rm -rf -- "$item"
done
echo "✅ Selected items deleted. I can feel the space 🚀"
fi
}

perform_copy_legacy() {
for item in "${selected_items[@]}"; do
[ ! -e "$item" ] && continue
local base=$(basename -- "$item")
local name="${base%.*}"
local ext="${base##*.}"
[[ "$base" == "$ext" ]] && ext=""
local count=1
local newbase="$base"
while [ -e "$path/$newbase" ]; do
if [ -n "$ext" ]; then
newbase="${name}${count}.${ext}"
else
newbase="${name}${count}"
fi
count=$((count+1))
done
cp -r -- "$item" "$path/$newbase"
done
}

fast_count() {
local pattern="$1"
local arr=("$pattern")
echo "${#arr[@]}"
}

count_items_in_path() {
local p="$1"
local total
if $show_hidden_files; then
local a=("$p"/*)
local b=("$p"/.*)
local count_a="${#a[@]}"
local count_b="${#b[@]}"
[[ "${a[0]}" == "$p/*" ]] && count_a=0
local filtered=0
for x in "${b[@]}"; do
local bn; bn=$(basename "$x")
[[ "$bn" == "." || "$bn" == ".." ]] && continue
((filtered++))
done
total=$((count_a + filtered))
else
local a=("$p"/*)
total="${#a[@]}"
[[ "${a[0]}" == "$p/*" ]] && total=0
fi
echo "$total"
}

build_items_for_prefix() {
local p="$1"
local pfx="$2"
items=()
while IFS= read -r -d '' f; do
local bn="${f##*/}"
[[ "$bn" == "." || "$bn" == ".." ]] && continue
! $show_hidden_files && [[ "$bn" == .* ]] && continue
[[ "${bn,,}" != "$pfx"* ]] && continue
items+=("$f")
done < <(find "$p" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
}

build_all_items() {
local p="$1"
items=()
if $show_hidden_files; then
for f in "$p"/* "$p"/.*; do
[ -e "$f" ] || continue
local bn; bn=$(basename "$f")
[[ "$bn" == "." || "$bn" == ".." ]] && continue
items+=("$f")
done
else
for f in "$p"/*; do
[ -e "$f" ] || continue
items+=("$f")
done
fi
}

get_imaginary_groups() {
local p="$1"
local pfx="$2"
declare -gA group_counts=()
group_chars=()
local chars=()
local -A _seen_chars=()

while IFS= read -r -d '' entry; do
local bn="${entry##*/}"
[[ "$bn" == "." || "$bn" == ".." ]] && continue
if ! $show_hidden_files && [[ "$bn" == .* ]]; then
continue
fi
[[ ${#bn} -le ${#pfx} ]] && continue
local bn_lower="${bn,,}"
[[ "$bn_lower" != "$pfx"* ]] && continue
local next="${bn_lower:${#pfx}:1}"
local upper="${next^^}"
if [[ "$upper" =~ ^[A-Z]$ ]]; then
group_counts["$upper"]=$(( ${group_counts["$upper"]:-0} + 1 ))
[ -z "${_seen_chars["$upper"]+x}" ] && chars+=("$upper") && _seen_chars["$upper"]=1
else
group_counts["#"]=$(( ${group_counts["#"]:-0} + 1 ))
[ -z "${_seen_chars["#"]+x}" ] && _seen_chars["#"]=1
fi
done < <(find "$p" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)

[ "${group_counts[#]:-0}" -gt 0 ] && chars+=("#")
group_chars=("${chars[@]}")
}

display_imaginary_groups() {
local p="$1"
local pfx="$2"
local total="$3"
echo "📂 Too many items ($total). Imaginary groups by next character:"
get_imaginary_groups "$p" "$pfx"
imaginary_map=()
local idx=1
for ch in "${group_chars[@]}"; do
local cnt="${group_counts[$ch]}"
printf " %2d) 📁 %s (%d items)\n" "$idx" "$ch" "$cnt"
imaginary_map+=("$ch")
idx=$((idx+1))
done
}

# ─────────────────────────────────────────────
# GLOBALS
# ─────────────────────────────────────────────
path=$(pwd)
move_mode=false
copy_mode=false
selected_items=()
original_path=""
group_prefix=""
force_show=false
declare -a imaginary_map=()
declare -a group_chars=()
declare -A group_counts=()
nav_result_path=""
nav_selected_items=()
gcloud_nav_result_path=""
gcloud_nav_selected_items=()

if [ $# -eq 1 ]; then
target="$1"
if [ -d "$target" ]; then
path=$(get_abs_path "$target")
elif [ -f "$target" ]; then
selected=$(get_abs_path "$target")
handle_file "$selected"
exit $?
else
echo "❌ Error: '$target' not found" >&2
exit 1
fi
fi

shopt -s nullglob
while true; do
echo
echo "📂 Location: $path${group_prefix:+ [filter: ${group_prefix^^}*]}"

total=$(count_items_in_path "$path")

imaginary_mode=false
items=()

if [ "$total" -gt "${index_mode_threshold:-200}" ] && ! $force_show; then
imaginary_mode=true
if [ -n "$group_prefix" ]; then
local_arr=()
while IFS= read -r -d '' _f; do
_bn="${_f##*/}"
[[ "$_bn" == "." || "$_bn" == ".." ]] && continue
! $show_hidden_files && [[ "$_bn" == .* ]] && continue
[[ "${_bn,,}" != "$group_prefix"* ]] && continue
local_arr+=("$_f")
done < <(find "$path" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
pfx_count="${#local_arr[@]}"
if [ "$pfx_count" -le "${index_mode_threshold:-200}" ]; then
imaginary_mode=false
items=("${local_arr[@]}")
else
display_imaginary_groups "$path" "$group_prefix" "$pfx_count"
fi
else
display_imaginary_groups "$path" "" "$total"
fi
fi

if ! $imaginary_mode; then
if [ ${#items[@]} -eq 0 ] && [ -n "$group_prefix" ]; then
build_items_for_prefix "$path" "$group_prefix"
elif [ ${#items[@]} -eq 0 ]; then
build_all_items "$path"
fi
if [ ${#items[@]} -eq 0 ]; then
echo "🛑 This directory is empty"
else
idx=1
for item in "${items[@]}"; do
[ -d "$item" ] && icon="📁" || icon="📄"
printf "%2d) %s %s\n" "$idx" "$icon" "$(basename "$item")"
idx=$((idx+1))
done
fi
fi
echo

echo "u) Up   cd) Change directory   t) Transfer"
echo "d) Delete   c) Create   f) Find   x) Organise   r) Rename"
echo "q/h) Quit/Home   s) Settings   forceshow) Toggle force show all"
[ -n "$group_prefix" ] && echo "back) Remove last prefix char (current: ${group_prefix^^}*)"

read -p "Select: " choice

case "$choice" in
q|Q|h|H)
exit 0
;;
u|U)
if [ "$path" != "/" ]; then
path=$(dirname "$path")
group_prefix=""
force_show=false
fi
continue
;;
back)
if [ -n "$group_prefix" ]; then
group_prefix="${group_prefix%?}"
force_show=false
fi
continue
;;
forceshow)
if $force_show; then
force_show=false
echo "🔓 Force show disabled"
else
force_show=true
echo "🔓 Force show enabled — displaying all items"
fi
continue
;;
c|C)
echo "Create:"
echo "1) New folders"
echo "2) New files"
read -p "Choice: " cr
[[ "$cr" == "1" ]] && create_dirs
[[ "$cr" == "2" ]] && create_files
continue
;;
t|T)
transfer_menu
continue
;;
d|D)
delete_items
continue
;;
f|F)
find_menu
continue
;;
x|X)
organise_menu
continue
;;
s|S)
settings_menu
continue
;;
r|R)
echo "Rename:"
echo "1) Select item number to rename (files/folders in current path)"
echo "2) Rename current path/folder"
read -p "Choice [1-2]: " ren_choice
case "$ren_choice" in
1)
if $imaginary_mode; then
echo "Select group number to browse for rename:"
read -p "Group number: " gnum
if [[ $gnum =~ ^[0-9]+$ ]] && [ "$gnum" -ge 1 ] && [ "$gnum" -le "${#imaginary_map[@]}" ]; then
ch="${imaginary_map[$((gnum-1))]}"
ch_lower="${ch,,}"
items=()
while IFS= read -r -d '' _f; do
_bn="${_f##*/}"
[[ "$_bn" == "." || "$_bn" == ".." ]] && continue
! $show_hidden_files && [[ "$_bn" == .* ]] && continue
_bn_lower="${_bn,,}"
[[ "$_bn_lower" != "$group_prefix"* ]] && continue
_next="${_bn_lower:${#group_prefix}:1}"
if [ "$ch" == "#" ]; then
[[ "$_next" =~ ^[a-z]$ ]] && continue
else
[[ "$_next" != "$ch_lower" ]] && continue
fi
items+=("$_f")
done < <(find "$path" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
idx=1
for item in "${items[@]}"; do
[ -d "$item" ] && icon="📁" || icon="📄"
printf "%2d) %s %s\n" "$idx" "$icon" "$(basename "$item")"
idx=$((idx+1))
done
read -p "Enter item number: " num
if [[ $num =~ ^[0-9]+$ ]] && [ "$num" -ge 1 ] && [ "$num" -le "${#items[@]}" ]; then
rename_item "${items[$((num-1))]}"
else
echo "❌ Invalid number"
fi
else
echo "❌ Invalid group"
fi
elif [ ${#items[@]} -eq 0 ]; then
echo "❌ No items to rename"
else
read -p "Enter item number: " num
if [[ $num =~ ^[0-9]+$ ]] && [ "$num" -ge 1 ] && [ "$num" -le "${#items[@]}" ]; then
rename_item "${items[$((num-1))]}"
else
echo "❌ Invalid number"
fi
fi
;;
2)
rename_item "$path"
;;
*)
echo "❌ Invalid choice"
;;
esac
continue
;;
cd|CD|cD|Cd)
cd "$path" && exec "$SHELL"
;;
esac

if $imaginary_mode; then
matched=false
if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#imaginary_map[@]}" ]; then
ch="${imaginary_map[$((choice-1))]}"
matched=true
elif [[ ${#choice} -eq 1 ]]; then
ch="${choice^^}"
for gc in "${group_chars[@]}"; do
[[ "$gc" == "$ch" ]] && matched=true && break
done
[[ "$matched" == false && "$choice" == "#" ]] && ch="#" && matched=true
fi

if $matched; then
if [ "$ch" == "#" ]; then
group_prefix="${group_prefix}#"
else
group_prefix="${group_prefix}${ch,,}"
fi
force_show=false
else
echo "⚠️  Invalid selection"
fi
else
if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#items[@]}" ]; then
selected="${items[$((choice-1))]}"
if [ -d "$selected" ]; then
path="$selected"
group_prefix=""
force_show=false
elif [ -f "$selected" ]; then
handle_file "$selected"
fi
else
echo "⚠️  Invalid selection"
fi
fi

done
