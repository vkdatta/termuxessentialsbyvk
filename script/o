#!/usr/bin/env bash

source "0_run.sh"
source "0_organise.sh"
source "0_find.sh"
source "bashbasicsbyvk_settings.sh"

MAX_ITEMS=200
force_show=false
group_prefix=""
last_path=""

parse_selection() {
    local input="$1"
    local max="$2"
    local -a indices=()
    IFS=',' read -ra parts <<< "$input"
    for part in "${parts[@]}"; do
        part=$(echo "$part" | xargs)
        if [[ $part =~ ^([0-9]+)-([0-9]+)$ ]]; then
            local start="${BASH_REMATCH[1]}"
            local end="${BASH_REMATCH[2]}"
            for ((i=start; i<=end && i<=max; i++)); do
                indices+=("$i")
            done
        elif [[ $part =~ ^[0-9]+$ ]]; then
            local num="$part"
            (( num >= 1 && num <= max )) && indices+=("$num")
        fi
    done
    echo "${indices[@]}"
}

select_items_common() {
    local prompt="$1"
    if [ ${#items[@]} -eq 0 ]; then
        echo "❌ No items available"
        return 1
    fi
    echo "$prompt (supports ranges: 1-10,15-20,33)"
    read -p "Item numbers: " itemlist
    local indices=($(parse_selection "$itemlist" "${#items[@]}"))
    selected_items=()
    for idx in "${indices[@]}"; do
        selected_items+=("${items[$((idx-1))]}")
    done
    if [ ${#selected_items[@]} -eq 0 ]; then
        echo "❌ No valid items selected"
        return 1
    fi
    echo "📦 Selected:"
    for item in "${selected_items[@]}"; do
        echo "   - $(basename "$item")"
    done
    return 0
}

rename_item() {
    local target="$1"
    local dir newname
    if [ -d "$target" ]; then
        dir=$(dirname -- "$target")
        read -p "📝 Enter new folder name for '$(basename "$target")': " newname
        mv -v "$target" "$dir/$newname"
    elif [ -f "$target" ]; then
        dir=$(dirname -- "$target")
        read -p "📝 Enter new file name for '$(basename "$target")': " newname
        mv -v "$target" "$dir/$newname"
    else
        echo "❌ Cannot rename: '$target' not found." >&2
        return 1
    fi
}

get_abs_path() {
    local target="$1"
    if [ -d "$target" ]; then
        cd -- "$target" && pwd
    elif [ -f "$target" ]; then
        local dir=$(dirname -- "$target")
        local base=$(basename -- "$target")
        echo "$(cd -- "$dir" && pwd)/$base"
    else
        echo "Error: '$target' does not exist" >&2
        return 1
    fi
}

create_files() {
    read -p "📄 Enter filenames (separated by ,): " filelist
    IFS=',' read -ra files <<< "$filelist"
    for file in "${files[@]}"; do
        touch "$path/$file"
        echo "✅ Created file: $file"
    done
}

create_dirs() {
    read -p "📂 Enter folder names (separated by ,): " dirlist
    IFS=',' read -ra dirs <<< "$dirlist"
    for dir in "${dirs[@]}"; do
        mkdir -p "$path/$dir"
        echo "✅ Created folder: $dir"
    done
}

move_items() {
    if select_items_common "MOVE"; then
        original_path="$path"
        path="$HOME"
        move_mode=true
        echo "🌍 MOVE MODE: Navigate to destination folder (press 'c' to confirm, 'x' to cancel)"
    fi
}

delete_items() {
    if select_items_common "DELETE"; then
        echo "⚠️  WARNING: You are about to delete the following items:"
        for item in "${selected_items[@]}"; do
            echo "- $(basename "$item")"
        done
        read -p "Are you sure? This cannot be undone. (y/n): " confirm
        if [[ $confirm != "y" && $confirm != "Y" ]]; then
            echo "🚫 Deletion cancelled"
            return
        fi
        for item in "${selected_items[@]}"; do
            rm -rf -- "$item" && echo "🗑️  Deleted: $(basename "$item")"
        done
    fi
}

initiate_copy() {
    if select_items_common "COPY"; then
        echo "Choose copy target:"
        echo "1) Local (navigate)"
        echo "2) Google Drive via rclone"
        read -p "Enter choice [1-2]: " copy_choice
        case "$copy_choice" in
            1)
                original_path="$path"
                path="$HOME"
                copy_mode=true
                echo "📋 COPY MODE: Navigate to destination folder (press 'c' to confirm, 'x' to cancel)"
                ;;
            2)
                if ! command -v rclone >/dev/null 2>&1; then
                    echo "❌ rclone not found in PATH."
                    selected_items=()
                    return
                fi
                local remote_path="gdrive:/rclone"
                for item in "${selected_items[@]}"; do
                    local base=$(basename "$item")
                    echo "📤 Copying $base → gdrive..."
                    rclone copy "$item" "$remote_path/$base" --progress --metadata
                done
                selected_items=()
                ;;
            *)
                selected_items=()
                ;;
        esac
    fi
}

perform_copy() {
    for item in "${selected_items[@]}"; do
        [ ! -e "$item" ] && continue
        local base=$(basename -- "$item")
        local name="${base%.*}"
        local ext="${base##*.}"
        [[ "$base" == "$ext" ]] && ext=""
        local count=1
        local newbase="$base"
        while [ -e "$path/$newbase" ]; do
            if [ -n "$ext" ]; then
                newbase="${name}_${count}.${ext}"
            else
                newbase="${name}_${count}"
            fi
            count=$((count+1))
        done
        cp -r -- "$item" "$path/$newbase"
        echo "📋 Copied: $(basename "$item") → $newbase"
    done
}

fast_count() {
    if $show_all_types; then
        find "$path" -maxdepth 1 \( -name ".*" -o -name "*" \) ! -name "." ! -name ".." -print 2>/dev/null | wc -l
    else
        find "$path" -maxdepth 1 ! -name ".*" ! -name "." ! -name ".." -print 2>/dev/null | wc -l
    fi
}

build_items_for_prefix() {
    local prefix="$1"
    local pattern
    items=()
    if [ -n "$prefix" ]; then
        pattern="$path/$prefix*"
    else
        pattern="$path/*"
    fi
    if $show_all_types; then
        shopt -s nullglob dotglob nocaseglob
        for f in $pattern; do
            [ -e "$f" ] || continue
            [[ "$(basename "$f")" == "." || "$(basename "$f")" == ".." ]] && continue
            items+=("$f")
        done
        shopt -u nullglob dotglob nocaseglob
    else
        shopt -s nullglob nocaseglob
        for f in $pattern; do
            [ -e "$f" ] || continue
            items+=("$f")
        done
        shopt -u nullglob nocaseglob
    fi
}

count_items_for_prefix() {
    local prefix="$1"
    if [ -n "$prefix" ]; then
        if $show_all_types; then
            find "$path" -maxdepth 1 -name "$prefix*" -o -name ".*$prefix*" ! -name "." ! -name ".." -print 2>/dev/null | wc -l
        else
            find "$path" -maxdepth 1 -name "$prefix*" ! -name ".*" -print 2>/dev/null | wc -l
        fi
    else
        fast_count
    fi
}

get_group_counts() {
    local base_prefix="$1"
    local -n folder_ref=$2
    local -n file_ref=$3
    folder_ref=()
    file_ref=()
    local -A folder_counts file_counts
    local pattern item base next_char
    if [ -n "$base_prefix" ]; then
        pattern="$path/$base_prefix*"
    else
        pattern="$path/*"
    fi
    if $show_all_types; then
        shopt -s nullglob dotglob nocaseglob
        for item in $pattern; do
            [ -e "$item" ] || continue
            [[ "$(basename "$item")" == "." || "$(basename "$item")" == ".." ]] && continue
            base=$(basename "$item")
            next_char="${base:${#base_prefix}:1}"
            next_char="${next_char^^}"
            [[ ! "$next_char" =~ [A-Z] ]] && next_char="#"
            if [ -d "$item" ]; then
                ((folder_counts[$next_char]++))
            else
                ((file_counts[$next_char]++))
            fi
        done
        shopt -u nullglob dotglob nocaseglob
    else
        shopt -s nullglob nocaseglob
        for item in $pattern; do
            [ -e "$item" ] || continue
            base=$(basename "$item")
            next_char="${base:${#base_prefix}:1}"
            next_char="${next_char^^}"
            [[ ! "$next_char" =~ [A-Z] ]] && next_char="#"
            if [ -d "$item" ]; then
                ((folder_counts[$next_char]++))
            else
                ((file_counts[$next_char]++))
            fi
        done
        shopt -u nullglob nocaseglob
    fi
    for k in "${!folder_counts[@]}"; do folder_ref[$k]=${folder_counts[$k]}; done
    for k in "${!file_counts[@]}"; do file_ref[$k]=${file_counts[$k]}; done
}

path=$(pwd)
move_mode=false
copy_mode=false
selected_items=()
original_path=""
shopt -s nullglob

if [ $# -eq 1 ]; then
    target="$1"
    if [ -d "$target" ]; then
        path=$(get_abs_path "$target")
    elif [ -f "$target" ]; then
        selected=$(get_abs_path "$target")
        handle_file "$selected"
        exit $?
    else
        echo "❌ Error: '$target' not found" >&2
        exit 1
    fi
fi

while true; do
    echo
    if [ "$path" != "$last_path" ]; then
        force_show=false
        group_prefix=""
        last_path="$path"
    fi
    if $move_mode; then
        echo "🚚 MOVE MODE: Select destination folder"
    elif $copy_mode; then
        echo "📋 COPY MODE: Select destination folder"
    else
        echo "📂 Location: $path"
    fi

    if [ -n "$group_prefix" ]; then
        current_prefix="$group_prefix"
    else
        current_prefix=""
    fi

    total=$(count_items_for_prefix "$current_prefix")

    if [ -n "$current_prefix" ] || [ "$force_show" = true ] || (( total <= MAX_ITEMS )); then
        build_items_for_prefix "$current_prefix"
        if [ ${#items[@]} -eq 0 ]; then
            echo "🛑 No items match this filter"
        else
            idx=1
            for item in "${items[@]}"; do
                [ -d "$item" ] && icon="📁" || icon="📄"
                printf "%2d) %s %s\n" "$idx" "$icon" "$(basename "$item")"
                idx=$((idx+1))
            done
        fi
    else
        declare -A folder_counts file_counts
        get_group_counts "$current_prefix" folder_counts file_counts
        echo "📂 Too many items ($total). Grouped by next character:"
        if [ ${#folder_counts[@]} -ne 0 ]; then
            echo "Folders:"
            for k in $(printf "%s\n" "${!folder_counts[@]}" | sort); do
                printf " %s) %d\n" "$k" "${folder_counts[$k]}"
            done
        fi
        if [ ${#file_counts[@]} -ne 0 ]; then
            echo "Files:"
            for k in $(printf "%s\n" "${!file_counts[@]}" | sort); do
                printf " %s) %d\n" "$k" "${file_counts[$k]}"
            done
        fi
        echo "Type a letter (or #) to drill down"
        items=()
    fi

    echo
    if $move_mode || $copy_mode; then
        echo "c) Confirm   x) Cancel"
    else
        if [ -n "$group_prefix" ]; then
            echo "back) Back to previous group"
        fi
        echo "u) Up directory   cd) change directory   t) Transfer (move/copy)"
        echo "d) Delete  c) Create  f) Find  x) Organise  r) Rename"
        echo "q/h) Quit/Home s) Settings"
        if [ -z "$group_prefix" ] && (( total > MAX_ITEMS )) && [ "$force_show" != true ]; then
            echo "forceshow) Show all items (may be slow)"
        fi
    fi

    read -p "Select item number or command: " choice

    choice_trimmed=$(echo "$choice" | xargs)
    choice_upper="${choice_trimmed^^}"

    if $move_mode; then
        case "$choice_trimmed" in
            c|C)
                for item in "${selected_items[@]}"; do
                    mv -v "$item" "$path/"
                done
                echo "✅ Items moved successfully"
                move_mode=false
                path="$original_path"
                selected_items=()
                group_prefix=""
                continue
                ;;
            x|X)
                echo "🚫 Move operation cancelled"
                move_mode=false
                path="$original_path"
                selected_items=()
                group_prefix=""
                continue
                ;;
        esac
    fi

    if $copy_mode; then
        case "$choice_trimmed" in
            c|C)
                perform_copy
                echo "✅ Items copied successfully"
                copy_mode=false
                path="$original_path"
                selected_items=()
                group_prefix=""
                continue
                ;;
            x|X)
                echo "🚫 Copy operation cancelled"
                copy_mode=false
                path="$original_path"
                selected_items=()
                group_prefix=""
                continue
                ;;
        esac
    fi

    case "$choice_trimmed" in
        q|Q|h|H) exit 0 ;;
        u|U)
            [ "$path" != "/" ] && path=$(dirname "$path")
            group_prefix=""
            continue
            ;;
        back|BACK|b|B)
            if [ -n "$group_prefix" ]; then
                group_prefix="${group_prefix%?}"
            fi
            continue
            ;;
        forceshow|FORCESHOW)
            force_show=true
            group_prefix=""
            continue
            ;;
        c|C)
            echo "1) New folders"
            echo "2) New files"
            read -p "Choice: " cr
            [[ "$cr" == "1" ]] && create_dirs
            [[ "$cr" == "2" ]] && create_files
            continue
            ;;
        t|T)
            echo "1) Move files/folders"
            echo "2) Copy files/folders"
            read -p "Choice: " tr
            [[ "$tr" == "1" ]] && move_items
            [[ "$tr" == "2" ]] && initiate_copy
            continue
            ;;
        d|D)
            delete_items
            continue
            ;;
        f|F)
            find_menu
            continue
            ;;
        x|X)
            organise_menu
            continue
            ;;
        s|S)
            settings_menu
            continue
            ;;
        r|R)
            echo "1) Select item number to rename (files/folders in current path)"
            echo "2) Rename current path/folder"
            read -p "Choice [1-2]: " ren_choice
            case "$ren_choice" in
                1)
                    if [ ${#items[@]} -eq 0 ]; then
                        echo "❌ No items to rename"
                    else
                        read -p "Enter item number: " num
                        if [[ $num =~ ^[0-9]+$ ]] && [ "$num" -ge 1 ] && [ "$num" -le "${#items[@]}" ]; then
                            rename_item "${items[$((num-1))]}"
                        else
                            echo "❌ Invalid number"
                        fi
                    fi
                    ;;
                2)
                    rename_item "$path"
                    ;;
                *)
                    echo "❌ Invalid choice"
                    ;;
            esac
            continue
            ;;
        cd|CD|cD|Cd)
            cd "$path" && exec "$SHELL"
            ;;
    esac

    if [ ${#items[@]} -gt 0 ] && [[ $choice_trimmed =~ ^[0-9]+$ ]] && [ "$choice_trimmed" -ge 1 ] && [ "$choice_trimmed" -le "${#items[@]}" ]; then
        selected="${items[$((choice_trimmed-1))]}"
        if [ -d "$selected" ]; then
            path="$selected"
            group_prefix=""
        elif [ -f "$selected" ]; then
            if $move_mode || $copy_mode; then
                echo "⚠️  Please select a folder for destination"
            else
                handle_file "$selected"
            fi
        fi
    elif [ ${#items[@]} -eq 0 ] && [[ "$choice_upper" =~ ^[A-Z]$ || "$choice_upper" == "#" ]]; then
        if [ -n "$group_prefix" ]; then
            group_prefix+="$choice_upper"
        else
            group_prefix="$choice_upper"
        fi
    else
        if [ -n "$choice_trimmed" ]; then
            echo "⚠️  Invalid selection"
        fi
    fi
done
