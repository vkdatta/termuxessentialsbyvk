#!/usr/bin/env python3
import os
import csv

try:
    import pandas as pd
    HAS_PANDAS = True
except ImportError:
    HAS_PANDAS = False


def format_value(val):
    escaped = str(val).replace("'", "''")
    return f"'{escaped}'"


def read_file(filepath, ext):
    if ext == ".csv":
        with open(filepath, newline="", encoding="utf-8-sig") as f:
            rows = [r for r in csv.reader(f) if any(c.strip() for c in r)]
        if not rows:
            return None, None
        return [h.strip() for h in rows[0]], rows[1:]
    else:
        if not HAS_PANDAS:
            print("\n  ERROR: pandas + openpyxl required.  pip install pandas openpyxl\n")
            return None, None
        df = pd.read_excel(filepath, dtype=str, keep_default_na=False, na_values=[])
        return list(df.columns), df.values.tolist()


print("=" * 60)
print("  CSV / EXCEL  →  SQL INSERT GENERATOR")
print("=" * 60)

cwd     = os.getcwd()
ALLOWED = {".csv", ".xlsx", ".xls", ".xlsm"}

while True:
    filename = input("\nEnter file name (with extension): ").strip()
    if not filename:
        continue
    ext = os.path.splitext(filename)[1].lower()
    if ext not in ALLOWED:
        print(f"  Only {', '.join(sorted(ALLOWED))} files are accepted.")
        continue
    filepath = os.path.join(cwd, filename)
    if not os.path.isfile(filepath):
        print(f"  File not found: {filepath}")
        continue
    break

print(f"\n  Reading '{filename}' ...")
headers, body = read_file(filepath, ext)

if headers is None:
    print("  ERROR: Could not read file or file is empty. Exiting.")
    exit()

print(f"  Columns  : {len(headers)}")
print(f"  Data rows: {len(body)}")
print(f"  Headers  : {', '.join(headers)}")

print("""
Select INSERT type:
  1 = INSERT INTO
  2 = INSERT OR IGNORE INTO
  3 = INSERT OR REPLACE INTO
""")

while True:
    choice = input("Enter choice (1 / 2 / 3): ").strip()
    if choice == "1":
        insert_type = "INSERT INTO"; break
    if choice == "2":
        insert_type = "INSERT OR IGNORE INTO"; break
    if choice == "3":
        insert_type = "INSERT OR REPLACE INTO"; break
    print("  Please enter 1, 2 or 3.")

print(f"  --> Using: {insert_type}")

while True:
    table_name = input("\nEnter table name: ").strip()
    if table_name:
        break

col_list  = ", ".join(headers)
sql_lines = []

for row in body:
    padded = list(row) + [""] * (len(headers) - len(row))
    values = ", ".join(format_value(v) for v in padded[:len(headers)])
    sql_lines.append(f"{insert_type} {table_name} ({col_list}) VALUES ({values});")

out_name = f"{os.path.splitext(filename)[0]}_{table_name}.sql"
out_path = os.path.join(cwd, out_name)

with open(out_path, "w", encoding="utf-8") as f:
    f.write("\n".join(sql_lines))

print(f"\n  Done!  {len(body)} rows written → {out_path}\n")
