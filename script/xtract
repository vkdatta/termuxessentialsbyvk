#!/usr/bin/env python3
"""
XTRACT - Fast web content extractor
requests.Session  → connection pooling + cookie persistence (works on Termux/Android)
ThreadPoolExecutor → parallel fetching without asyncio native-lib dependencies
Homepage pre-fetch → establishes session cookies before paginated requests
"""

import os
import re
import subprocess
import sys
import time
import random
from concurrent.futures import ThreadPoolExecutor, as_completed
from urllib.parse import urljoin, urlparse

import requests
from bs4 import BeautifulSoup
import pandas as pd

# ─── One-time openpyxl import ─────────────────────────────────────────────────
try:
    import openpyxl
    EXCEL_AVAILABLE = True
except ImportError:
    EXCEL_AVAILABLE = False

# ─── Tuning ───────────────────────────────────────────────────────────────────
CONCURRENCY     = 5     # threads — low enough to avoid burst-blocks
REQUEST_TIMEOUT = 20    # seconds per request
MAX_RETRIES     = 4     # retries per failed page
RETRY_BACKOFF   = 2.0   # seconds before first retry (doubles each attempt)
STAGGER_DELAY   = 0.3   # seconds between starting each thread

HEADERS = {
    "User-Agent": (
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
        "AppleWebKit/537.36 (KHTML, like Gecko) "
        "Chrome/125.0.0.0 Safari/537.36"
    ),
    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8",
    "Accept-Language": "en-US,en;q=0.9",
    "Accept-Encoding": "gzip, deflate, br",
    "sec-ch-ua": '"Google Chrome";v="125", "Chromium";v="125", "Not.A/Brand";v="24"',
    "sec-ch-ua-mobile": "?0",
    "sec-ch-ua-platform": '"Windows"',
    "sec-fetch-dest": "document",
    "sec-fetch-mode": "navigate",
    "sec-fetch-site": "none",
    "sec-fetch-user": "?1",
    "upgrade-insecure-requests": "1",
}


# ─── Dependency helpers ───────────────────────────────────────────────────────
def _pip(pkg: str) -> bool:
    try:
        subprocess.check_call(
            [sys.executable, "-m", "pip", "install", pkg],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        return True
    except Exception:
        return False


def bootstrap():
    try:
        import lxml as _  # noqa: F401
    except ImportError:
        print("📦 Installing lxml (faster HTML parsing)…")
        _pip("lxml")


def ensure_openpyxl() -> bool:
    global EXCEL_AVAILABLE
    if EXCEL_AVAILABLE:
        return True
    print("\n❌ openpyxl missing (needed for Excel export)")
    if input("Install now? (y/n): ").strip().lower() == "y" and _pip("openpyxl"):
        import importlib
        globals()["openpyxl"] = importlib.import_module("openpyxl")
        EXCEL_AVAILABLE = True
        print("✅ openpyxl installed.")
        return True
    print("⚠️  Falling back to CSV.")
    return False


def _bs_parser() -> str:
    try:
        import lxml as _  # noqa: F401
        return "lxml"
    except ImportError:
        return "html.parser"


# ─── Filename helpers ─────────────────────────────────────────────────────────
def clean_sheet_name(name: str) -> str:
    return re.sub(r'[\\/*?:\[\]]', "", name)[:31]


def generate_unique_filename(base_path: str, fmt: str) -> str:
    base = os.path.splitext(base_path)[0]
    candidate = f"{base}.{fmt}"
    n = 0
    while os.path.exists(candidate):
        n += 1
        candidate = f"{base}_{n}.{fmt}"
    return candidate


# ─── URL / pagination parsing ─────────────────────────────────────────────────
def parse_url_spec(raw: str):
    """Returns (template_url, num_pages).  url/{42} → (url/{}, 42)."""
    raw = raw.strip()
    if not raw:
        return None, 0
    m = re.search(r'\{(\d+)\}', raw)
    if m:
        try:
            n = int(m.group(1))
        except ValueError:
            n = 1
        return re.sub(r'\{\d+\}', '{}', raw, count=1), n
    return raw, 1


# ─── HTML parsing ─────────────────────────────────────────────────────────────
_PARSER = None


def _get_parser() -> str:
    global _PARSER
    if _PARSER is None:
        _PARSER = _bs_parser()
    return _PARSER


def manual_table_extraction(table):
    try:
        headers, header_row = [], None

        thead = table.find("thead")
        if thead:
            for row in thead.find_all("tr"):
                headers = [c.get_text(strip=True) for c in row.find_all(["th", "td"])]
                if headers:
                    break

        if not headers:
            ths = table.find_all("th")
            if ths:
                headers = [th.get_text(strip=True) for th in ths]

        tbody = table.find("tbody") or table
        all_rows = tbody.find_all("tr")

        start_idx = 0
        if not headers and all_rows:
            header_row = all_rows[0]
            headers = [c.get_text(strip=True) for c in header_row.find_all(["th", "td"])]
            start_idx = 1

        rows_data = []
        for row in all_rows[start_idx:]:
            if row is header_row:
                continue
            cols = row.find_all(["td", "th"])
            if cols:
                rows_data.append([c.get_text(strip=True) for c in cols])

        if not rows_data:
            return None

        max_cols = max(len(r) for r in rows_data)
        if headers:
            if len(headers) > max_cols:
                headers = headers[:max_cols]
            elif len(headers) < max_cols:
                headers += [f"Column_{i+1}" for i in range(len(headers), max_cols)]

        padded = [r + [""] * (max_cols - len(r)) for r in rows_data]
        return pd.DataFrame(padded, columns=headers or None)

    except Exception as exc:
        print(f"    ⚠️  Table parse error: {exc}")
        return None


def _get_tables(container, table_classes=None):
    if table_classes:
        out = []
        for cls in table_classes:
            out.extend(container.find_all("table", class_=cls))
        return out
    return container.find_all("table")


def _get_links(container, link_classes=None):
    links = []
    for a in container.find_all("a", href=True):
        href = a["href"]
        if not href or href.startswith(("javascript:", "mailto:", "tel:")):
            continue
        text = a.get_text(strip=True)
        if link_classes:
            matched = [c for c in link_classes if c in a.get("class", [])]
            if matched:
                links.append({"url": href, "text": text, "classes": ",".join(matched)})
        else:
            links.append({"url": href, "text": text})
    return links


def parse_page(html_bytes: bytes, url: str, content_type: str,
               classes, ids, link_classes) -> list:
    soup = BeautifulSoup(html_bytes, _get_parser())
    containers = ([soup.find(id=cid) for cid in ids if soup.find(id=cid)]
                  if ids else [soup])
    if not containers:
        containers = [soup]

    results = []
    for container in containers:
        if content_type == "tables":
            for tbl in _get_tables(container, classes):
                df = manual_table_extraction(tbl)
                if df is not None and not df.empty:
                    results.append(df)
        else:
            for link in _get_links(container, link_classes):
                link["absolute_url"] = urljoin(url, link["url"])
                results.append(link)
    return results


# ─── Session factory ──────────────────────────────────────────────────────────
def make_session(base_url: str = None) -> requests.Session:
    """
    Create a requests.Session with connection pooling.
    If base_url given, pre-fetches the homepage to pick up any session
    cookies the server sets before you hit the numbered pages.
    """
    session = requests.Session()
    session.headers.update(HEADERS)

    # Increase connection pool size to match concurrency
    adapter = requests.adapters.HTTPAdapter(
        pool_connections=CONCURRENCY,
        pool_maxsize=CONCURRENCY * 2,
        max_retries=0,   # we do retries ourselves
    )
    session.mount("https://", adapter)
    session.mount("http://", adapter)

    if base_url:
        origin = f"{urlparse(base_url).scheme}://{urlparse(base_url).netloc}"
        try:
            print(f"🍪 Pre-fetching homepage to establish session: {origin}")
            session.get(origin, timeout=REQUEST_TIMEOUT)
            # Update Referer for subsequent requests
            session.headers.update({"Referer": origin, "sec-fetch-site": "same-origin"})
        except Exception:
            pass   # non-fatal

    return session


# ─── Per-thread fetch function ────────────────────────────────────────────────
def fetch_page_with_retry(args):
    """
    Runs in a thread. Uses the shared session (thread-safe for reads).
    Returns (url, results_list).
    """
    session, url, content_type, classes, ids, link_classes, idx = args

    # Stagger thread start times to avoid synchronized bursts
    time.sleep(idx * STAGGER_DELAY + random.uniform(0, 0.1))

    for attempt in range(MAX_RETRIES + 1):
        try:
            resp = session.get(url, timeout=REQUEST_TIMEOUT)

            if resp.status_code in (429, 500, 502, 503, 504):
                wait = RETRY_BACKOFF * (2 ** attempt)
                if attempt < MAX_RETRIES:
                    print(f"  🔄 HTTP {resp.status_code} – retry "
                          f"{attempt+1}/{MAX_RETRIES} in {wait:.1f}s: {url}")
                    time.sleep(wait)
                    continue
                print(f"  🚫 HTTP {resp.status_code} – gave up: {url}")
                return url, []

            if resp.status_code >= 400:
                print(f"  🚫 HTTP {resp.status_code}: {url}")
                return url, []

            results = parse_page(resp.content, url, content_type,
                                 classes, ids, link_classes)
            return url, results

        except requests.exceptions.Timeout:
            wait = RETRY_BACKOFF * (2 ** attempt)
            if attempt < MAX_RETRIES:
                print(f"  ⏱️  Timeout – retry {attempt+1}/{MAX_RETRIES} "
                      f"in {wait:.1f}s: {url}")
                time.sleep(wait)
                continue
            print(f"  ⏱️  Timeout – gave up: {url}")
            return url, []

        except requests.exceptions.RequestException as exc:
            wait = RETRY_BACKOFF * (2 ** attempt)
            if attempt < MAX_RETRIES:
                print(f"  🌐 {type(exc).__name__} – retry "
                      f"{attempt+1}/{MAX_RETRIES} in {wait:.1f}s: {url}")
                time.sleep(wait)
                continue
            print(f"  🌐 {type(exc).__name__} – gave up: {url}")
            return url, []

    return url, []


# ─── Parallel fetch engine ────────────────────────────────────────────────────
def extract_url_concurrent(url_template, content_type, num_pages=1,
                            classes=None, ids=None, link_classes=None):
    page_urls = (
        [url_template.format(p) for p in range(1, num_pages + 1)]
        if "{}" in url_template else [url_template]
    )
    total = len(page_urls)
    print(f"⏳ Fetching {total} page(s) — "
          f"{CONCURRENCY} threads, staggered {STAGGER_DELAY}s apart…")

    # One shared session: connection pool + cookies across all threads
    session = make_session(page_urls[0])

    args_list = [
        (session, url, content_type, classes, ids, link_classes, idx)
        for idx, url in enumerate(page_urls)
    ]

    all_content = []
    completed   = 0

    with ThreadPoolExecutor(max_workers=CONCURRENCY) as pool:
        futures = {pool.submit(fetch_page_with_retry, args): args[1]
                   for args in args_list}
        for future in as_completed(futures):
            url, results = future.result()
            completed += 1
            if results:
                all_content.extend(results)
                tag = f"{len(results)} {'table(s)' if content_type == 'tables' else 'link(s)'}"
                print(f"  ✅ [{completed}/{total}] {url}  — {tag}")
            else:
                print(f"  ⚠️  [{completed}/{total}] {url}  — no content")

    return all_content


# ─── Table grouping ───────────────────────────────────────────────────────────
def group_tables(tables):
    if not tables:
        return []
    groups, current = [], [tables[0]]
    for tbl in tables[1:]:
        if list(tbl.columns) == list(current[-1].columns):
            current.append(tbl)
        else:
            groups.append(current)
            current = [tbl]
    groups.append(current)
    return groups


# ─── Save helpers ─────────────────────────────────────────────────────────────
def _write_groups_to_sheet(ws, groups):
    row = 1
    for g_idx, group in enumerate(groups):
        ws.cell(row=row, column=1, value=f"Table Group {g_idx + 1}")
        row += 1
        for col, h in enumerate(group[0].columns.tolist(), 1):
            ws.cell(row=row, column=col, value=h)
        row += 1
        for tbl in group:
            for _, data_row in tbl.iterrows():
                for col, val in enumerate(data_row, 1):
                    ws.cell(row=row, column=col, value=val)
                row += 1
        row += 5


def save_tables_excel(tables, output_path, source_url=None):
    if not EXCEL_AVAILABLE:
        print("❌ openpyxl unavailable – saving as CSV.")
        return save_tables_csv(tables, os.path.splitext(output_path)[0] + ".csv")
    try:
        wb = openpyxl.Workbook()
        wb.remove(wb.active)
        domain = urlparse(source_url).netloc.replace("www.", "")[:15] if source_url else "Data"
        ws = wb.create_sheet(clean_sheet_name(f"{domain}_Data"))
        _write_groups_to_sheet(ws, group_tables(tables))
        wb.save(output_path)
        print(f"💾 Excel saved → {os.path.abspath(output_path)}")
        return True
    except Exception as exc:
        print(f"🚨 Excel save failed: {exc}")
        return False


def save_tables_csv(tables, output_path):
    try:
        pd.concat(tables, ignore_index=True).to_csv(output_path, index=False)
        print(f"💾 CSV saved → {os.path.abspath(output_path)}")
        return True
    except Exception as exc:
        print(f"🚨 CSV save failed: {exc}")
        return False


def save_links(links, output_path, source_url=None):
    ext = os.path.splitext(output_path)[1].lower()
    df  = pd.DataFrame(links)
    try:
        if ext == ".txt":
            with open(output_path, "w") as f:
                for lnk in links:
                    f.write(lnk.get("absolute_url", lnk["url"]) + "\n")
        elif ext == ".csv":
            df.to_csv(output_path, index=False)
        elif ext == ".xlsx":
            if not EXCEL_AVAILABLE:
                return save_links(links, os.path.splitext(output_path)[0] + ".csv", source_url)
            domain = urlparse(source_url).netloc.replace("www.", "")[:15] if source_url else "Links"
            with pd.ExcelWriter(output_path, engine="openpyxl") as w:
                df.to_excel(w, sheet_name=clean_sheet_name(f"{domain}_Links"), index=False)
        else:
            print(f"❌ Unknown format '{ext}' – saving as links.txt")
            return save_links(links, "links.txt", source_url)
        print(f"💾 Saved → {os.path.abspath(output_path)}")
        return True
    except Exception as exc:
        print(f"🚨 Save failed: {exc}")
        return False


def save_content(content, content_type, output_path, source_url=None):
    if not content:
        print("❌ No content to save.")
        return False
    out_dir = os.path.dirname(output_path)
    if out_dir:
        os.makedirs(out_dir, exist_ok=True)
    ext = os.path.splitext(output_path)[1].lower()
    if content_type == "tables":
        if ext == ".csv":
            return save_tables_csv(content, output_path)
        if ext == ".xlsx":
            return save_tables_excel(content, output_path, source_url)
        print("❌ Unknown format – defaulting to output.xlsx")
        return save_content(content, content_type, "output.xlsx", source_url)
    return save_links(content, output_path, source_url)


# ─── Input helpers ────────────────────────────────────────────────────────────
def parse_comma_separated(raw):
    if not raw:
        return None
    items = [x.strip() for x in raw.split(",") if x.strip()]
    return items or None


def prompt_non_empty(prompt, field="value"):
    while True:
        val = input(prompt).strip()
        if val:
            return val
        print(f"❌ {field} cannot be empty.")


# ─── Main ─────────────────────────────────────────────────────────────────────
def main():
    bootstrap()

    print("\n" + "=" * 54)
    print("🌐  XTRACT – FAST WEB CONTENT EXTRACTOR".center(54))
    print("=" * 54)

    ct = input("\nExtract tables or links? (t/l): ").strip().lower()
    if ct not in ("t", "l"):
        print("❌ Invalid selection.")
        return
    content_type = "tables" if ct == "t" else "links"

    classes = ids = link_classes = None
    if content_type == "tables":
        classes = parse_comma_separated(input("\nTable class(es) – optional, comma-separated:\n> "))
        ids     = parse_comma_separated(input("\nContainer ID(s) – optional, comma-separated:\n> "))
    else:
        link_classes = parse_comma_separated(input("\nLink class(es) – optional, comma-separated:\n> "))
        ids          = parse_comma_separated(input("\nContainer ID(s) – optional, comma-separated:\n> "))

    mode = input("\nSingle URL or Multiple URLs? (1/2): ").strip()

    # ── Single URL ─────────────────────────────────────────────────────────────
    if mode == "1":
        raw = prompt_non_empty("\nEnter website URL:\n> ", "URL")
        tpl, num_pages = parse_url_spec(raw)
        if not tpl:
            print("❌ Invalid URL.")
            return

        default_ext  = "xlsx" if content_type == "tables" else "txt"
        default_name = generate_unique_filename(
            urlparse(tpl).netloc.replace("www.", "")[:20], default_ext
        )
        filename = input(f"\nOutput filename (default: {default_name}):\n> ").strip() or default_name
        if "." not in os.path.basename(filename):
            filename += f".{default_ext}"

        t0      = time.perf_counter()
        content = extract_url_concurrent(tpl, content_type, num_pages, classes, ids, link_classes)
        elapsed = time.perf_counter() - t0
        print(f"\n⚡ {num_pages} page(s) fetched in {elapsed:.1f}s")

        if content:
            save_content(content, content_type, filename, tpl)
        else:
            print("❌ No content extracted. Check URL and parameters.")

    # ── Multiple URLs ──────────────────────────────────────────────────────────
    elif mode == "2":
        print("\nEnter URLs (space/comma separated, multiple lines OK).")
        print("Press Enter on an empty line when done:")
        lines = []
        while True:
            line = input("> ").strip()
            if line:
                lines.append(line)
            else:
                break

        url_specs = []
        for raw in re.split(r"[,\s]+", " ".join(lines)):
            if not raw:
                continue
            tpl, n = parse_url_spec(raw)
            if tpl:
                url_specs.append((tpl, n))

        if not url_specs:
            print("❌ No valid URLs found.")
            return
        print(f"\nFound {len(url_specs)} URL(s) to process.")

        output_mode = input("\nSave in single file or multiple files? (1/2): ").strip()

        if output_mode == "1":
            default_ext = "xlsx" if content_type == "tables" else "csv"
            raw_name    = input(f"\nOutput filename (default: combined.{default_ext}):\n> ").strip()
            filename    = raw_name or f"combined.{default_ext}"
            if "." not in os.path.basename(filename):
                filename += f".{default_ext}"

            if content_type == "tables" and filename.endswith(".xlsx"):
                ensure_openpyxl()
                wb = openpyxl.Workbook()
                wb.remove(wb.active)
                t0 = time.perf_counter()
                for i, (tpl, n) in enumerate(url_specs):
                    print(f"\n🔗 URL {i+1}/{len(url_specs)}: {tpl}")
                    content = extract_url_concurrent(tpl, content_type, n, classes, ids, link_classes)
                    if content:
                        domain = urlparse(tpl).netloc.replace("www.", "")[:15]
                        ws = wb.create_sheet(clean_sheet_name(f"{domain}_{i+1}"))
                        _write_groups_to_sheet(ws, group_tables(content))
                        print(f"  💾 Sheet added: {ws.title}")
                    else:
                        print(f"  ⚠️  No content for {tpl}")
                elapsed = time.perf_counter() - t0
                wb.save(filename)
                print(f"\n⚡ Done in {elapsed:.1f}s — "
                      f"{len(wb.sheetnames)} sheet(s) → {os.path.abspath(filename)}")
            else:
                all_content = []
                t0 = time.perf_counter()
                for i, (tpl, n) in enumerate(url_specs):
                    print(f"\n🔗 URL {i+1}/{len(url_specs)}: {tpl}")
                    all_content.extend(
                        extract_url_concurrent(tpl, content_type, n, classes, ids, link_classes)
                    )
                elapsed = time.perf_counter() - t0
                print(f"\n⚡ Fetched all pages in {elapsed:.1f}s")
                save_content(all_content, content_type, filename)

        elif output_mode == "2":
            out_dir = input("\nOutput directory (default: current directory):\n> ").strip()
            if out_dir:
                os.makedirs(out_dir, exist_ok=True)
            t0 = time.perf_counter()
            for i, (tpl, n) in enumerate(url_specs):
                print(f"\n🔗 URL {i+1}/{len(url_specs)}: {tpl}")
                content = extract_url_concurrent(tpl, content_type, n, classes, ids, link_classes)
                if content:
                    default_ext = "xlsx" if content_type == "tables" else "txt"
                    base      = urlparse(tpl).netloc.replace("www.", "")[:20]
                    base_path = os.path.join(out_dir, base) if out_dir else base
                    fname     = generate_unique_filename(base_path, default_ext)
                    save_content(content, content_type, fname, tpl)
            elapsed = time.perf_counter() - t0
            print(f"\n⚡ All URLs processed in {elapsed:.1f}s")

    print("\n✅ Extraction complete!")
    print("=" * 54 + "\n")


if __name__ == "__main__":
    main()
